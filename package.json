{
  "name": "nextjs-foundations-starter",
  "private": true,
  "scripts": {
    "start": "turbo run start",
    "start:web": "turbo run start --filter=@repo/web",
    "start:brands": "turbo run start --filter=@repo/brands",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=@repo/web",
    "build:brands": "turbo run build --filter=@repo/brands",
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@repo/web",
    "dev:brands": "turbo run dev --filter=@repo/brands",
    "storybook": "turbo run storybook --filter=@repo/storybook",
    "build-storybook": "turbo run build-storybook --filter=@repo/storybook",
    "check-types": "turbo run check-types",
    "lint": "turbo run lint",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "check": "turbo run lint && turbo run check-types"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.3.4",
    "@storybook/addon-docs": "^10.3.4",
    "@storybook/nextjs-vite": "^10.3.4",
    "eslint": "^9.39.2",
    "eslint-config-next": "16.2.1",
    "eslint-plugin-storybook": "^10.3.4",
    "prettier": "^3.7.4",
    "storybook": "^10.3.4",
    "turbo": "^2.8.21",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
  "engines": {
    "node": "24.x"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3",
      "typescript": "5.9.3"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  }
}
