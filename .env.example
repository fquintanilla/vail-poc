# Environment variables are defined per Next.js app. Copy the example for the app you run:
#
#   cp apps/web/.env.example apps/web/.env.local
#   cp apps/brands/.env.example apps/brands/.env.local
#
# Both apps share the same variable names (Contentstack, theme, revalidate, OpenWeather, etc.).
# See apps/web/.env.example for the full list and comments.
